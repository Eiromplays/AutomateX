# Copy to .env next to docker-compose.prod.yml and fill in. Keep .env out of git.

# Postgres password (any strong value; the DB is LAN/Tailscale-only).
POSTGRES_PASSWORD=change-me

# AES key for connection secrets. Generate once and never change it:
#   openssl rand -base64 32
ENCRYPTION_KEY=

# Public https origin AutomateX is reached at — the Tailscale Serve hostname.
# Used to build webhook URLs and OIDC redirect URIs.
PUBLIC_BASE_URL=https://automatex.your-tailnet.ts.net

# OIDC provider (Entra ID, Authentik, Keycloak, Auth0, …).
# Register the redirect URI  <PUBLIC_BASE_URL>/signin-oidc
# and post-logout URI        <PUBLIC_BASE_URL>/signout-callback-oidc  at the provider.
OIDC_AUTHORITY=https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Allow uploading plugins through the UI/API. Uploaded plugins run in-process with full host trust,
# so leave false unless you're actively adding one.
ALLOW_PLUGIN_UPLOAD=false
