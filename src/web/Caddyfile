:80 {
	handle /api/* {
		reverse_proxy api:8080
	}

	# WebSockets are proxied automatically.
	handle /hubs/* {
		reverse_proxy api:8080
	}

	# OIDC flow endpoints live on the API.
	handle /auth/* {
		reverse_proxy api:8080
	}

	handle /signin-oidc* {
		reverse_proxy api:8080
	}

	handle /signout-callback-oidc* {
		reverse_proxy api:8080
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
