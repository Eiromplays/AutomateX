# Trust X-Forwarded-* from upstream proxies on private/loopback addresses (Tailscale Serve, a LAN
# reverse proxy, the Docker bridge). Without this Caddy overwrites X-Forwarded-Proto with its own
# :80 listener scheme, so a TLS-terminating front (Tailscale → https) would look like http to the
# API and OIDC would build http:// redirect URIs.
{
	servers {
		trusted_proxies static private_ranges
	}
}

:80 {
	handle /api/* {
		reverse_proxy api:8080
	}

	# WebSockets are proxied automatically.
	handle /hubs/* {
		reverse_proxy api:8080
	}

	# OIDC flow endpoints live on the API.
	handle /auth/* {
		reverse_proxy api:8080
	}

	handle /signin-oidc* {
		reverse_proxy api:8080
	}

	handle /signout-callback-oidc* {
		reverse_proxy api:8080
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
